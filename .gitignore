# ── Dependencies ──────────────────────────────────────────────
# Match the folder anywhere in the tree (do not commit installs).
node_modules
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
.npm

# ── Build outputs ─────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
.output/

# ── Vite / PWA cache ──────────────────────────────────────────
.vite/
.vite-temp/
vite.config.ts.timestamp-*

# ── Environment variables ─────────────────────────────────────
# Never commit real secrets — use .env.example as a template
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
*.env

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

